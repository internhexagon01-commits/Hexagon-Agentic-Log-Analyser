# ── Guardrail ─────────────────────────────────────────────────────────
def apply_guardrail(text: str, source: str = "INPUT") -> str:
    if not GUARDRAIL_ID:
        return text
    try:
        resp = get_bedrock_runtime().apply_guardrail(
            guardrailIdentifier=GUARDRAIL_ID,
            guardrailVersion=GUARDRAIL_VER,
            source=source,
            content=[{"text": {"text": text}}],
        )
        if resp["action"] == "GUARDRAIL_INTERVENED":
            blocked = resp.get("outputs", [{}])[0].get("text", "Content blocked by guardrail.")
            raise ValueError(blocked)
    except ValueError:
        raise
    except Exception as e:
        print(f"[GUARDRAIL] failed: {e}")
    return text


# ── KB helpers ────────────────────────────────────────────────────────
_tool_call_log: list[dict] = []
_csv_cache: dict[str, pd.DataFrame] = {}


def _download_and_parse_key(bucket: str, key: str) -> pd.DataFrame:
    with tempfile.NamedTemporaryFile(mode="w+b", delete=False) as tmp:
        get_s3_client().download_fileobj(bucket, key, tmp)
        tmp.flush()
        tmp_path = tmp.name
    try:
        with open(tmp_path, "r", encoding="utf-8") as f:
            raw = f.read()
        try:
            data = json.loads(raw)
            rows = [e["contentMetadata"] for e in data.get("fileContents", []) if "contentMetadata" in e]
            df = pd.DataFrame(rows)
        except (json.JSONDecodeError, KeyError):
            df = pd.read_csv(io.StringIO(raw))
    finally:
        os.unlink(tmp_path)
    return df


def _download_and_parse(source_uri: str) -> pd.DataFrame:
    if source_uri in _csv_cache:
        return _csv_cache[source_uri]
    parsed = urlparse(source_uri)
    if parsed.scheme != "s3":
        raise ValueError(f"Invalid S3 URI: {source_uri}")
    bucket = parsed.netloc
    key    = parsed.path.lstrip("/")
    df = _download_and_parse_key(bucket, key)
    if "element_id" not in df.columns and not key.startswith("Output/"):
        df = _download_and_parse_key(bucket, f"Output/{key}")
    if "page_number" in df.columns:
        df["page_number"] = pd.to_numeric(df["page_number"], errors="coerce").fillna(0).astype(int)
    _csv_cache[source_uri] = df
    return df


def _resolve_data_uri(source_uri: str) -> str:
    if not source_uri.lower().endswith(".pdf"):
        return source_uri
    for entry in reversed(_tool_call_log):
        if entry.get("tool") != "kb_retriever":
            continue
        for el in entry["result"].get("elements", []):
            if el.get("source_uri") == source_uri and el.get("csv_source_uri"):
                return el["csv_source_uri"]
    raise ValueError(f"Cannot resolve data URI from PDF path: {source_uri}")


# ── NovAtel ASCII log parser ──────────────────────────────────────────
_log_store: dict[str, dict] = {}

# ── Answer cache ──────────────────────────────────────────────────────
# Keyed by (session_id, normalized_question) → answer string.
# Cleared automatically when a new file is uploaded for that session.
# Max 200 entries per session to avoid unbounded memory growth.
_answer_cache: dict[str, dict[str, str]] = {}
_ANSWER_CACHE_MAX = 200


def _normalize_question(text: str) -> str:
    """Lowercase, strip punctuation, collapse whitespace for cache key matching."""
    text = text.lower().strip()
    text = re.sub(r"[^\w\s]", "", text)
    text = re.sub(r"\s+", " ", text)
    return text


def _cache_get(session_id: str, question: str) -> str | None:
    key = _normalize_question(question)
    return _answer_cache.get(session_id, {}).get(key)


def _cache_set(session_id: str, question: str, answer: str) -> None:
    key = _normalize_question(question)
    if session_id not in _answer_cache:
        _answer_cache[session_id] = {}
    cache = _answer_cache[session_id]
    # Evict oldest entry if at capacity (simple FIFO)
    if len(cache) >= _ANSWER_CACHE_MAX:
        oldest = next(iter(cache))
        del cache[oldest]
    cache[key] = answer
    print(f"[CACHE] stored: session={session_id} key='{key[:60]}'")


def _cache_clear_session(session_id: str) -> None:
    """Called on new file upload so stale answers don't bleed into the new file."""
    if session_id in _answer_cache:
        del _answer_cache[session_id]
        print(f"[CACHE] cleared for session={session_id}")


_ASCII_FULL_RE = re.compile(
    r"^#(?P<log_name>[A-Z0-9_]+),"
    r"(?P<header>[^;]*);"
    r"(?P<fields>.*?)"
    r"(?:\*[0-9a-fA-F]{1,8})?\s*$"
)


def _parse_line(line: str) -> dict | None:
    m = _ASCII_FULL_RE.match(line.strip())
    if not m:
        return None
    g = m.groupdict()
    h = [p.strip() for p in g["header"].split(",")]

    def _get(i, d=""): return h[i] if i < len(h) else d
    def _tryf(v, d=0.0):
        try: return float(v)
        except Exception: return d
    def _tryi(v, d=0):
        try: return int(v)
        except Exception: return d

    log_name   = g["log_name"]
    normalized = log_name[:-1] if (log_name.endswith("A") and len(log_name) > 4) else log_name
    week       = _tryi(_get(4))
    seconds    = _tryf(_get(5))

    return {
        "log_name":     normalized,
        "log_name_raw": log_name,
        "port":         _get(0),
        "seq":          _tryi(_get(1)),
        "idle_pct":     _tryf(_get(2)),
        "time_status":  _get(3),
        "week":         week,
        "seconds":      seconds,
        "utc_time":     gps_to_utc_str(week, seconds),
        "rx_status":    _get(6),
        "fields_raw":   g["fields"],
    }


def parse_novatel_ascii(text: str) -> pd.DataFrame:
    records, skipped = [], 0
    for line in text.splitlines():
        if not line.strip():
            continue
        rec = _parse_line(line)
        if rec:
            records.append(rec)
        else:
            skipped += 1
    print(f"[PARSE] matched={len(records)} skipped={skipped}")
    return pd.DataFrame(records) if records else pd.DataFrame()


# ── RXSTATUS bit map ──────────────────────────────────────────────────
_RXSTATUS_BITS = {
    0:  "Error flag",
    1:  "Temperature status warning",
    2:  "Voltage supply status warning",
    3:  "Primary antenna not powered",
    4:  "LNA failure",
    5:  "Primary antenna open circuit",
    6:  "Primary antenna short circuit",
    7:  "CPU overload",
    8:  "COM port transmit buffer overrun",
    9:  "Spoofing detected",
    11: "Link overrun",
    12: "Input overrun",
    13: "Aux transmit overrun",
    14: "Antenna gain out of range",
    15: "Jammer detected",
    16: "INS reset",
    17: "IMU communication failure",
    18: "GPS almanac / UTC invalid",
    19: "Position solution invalid",
    20: "Position fixed",
    21: "Clock steering disabled",
    22: "Clock model invalid",
    23: "External oscillator locked",
    24: "Software resource warning",
    25: "Version bit 0",
    26: "Version bit 1",
    27: "HDR tracking mode",
    28: "Digital filtering enabled",
    29: "Auxiliary 3 status event",
    30: "Auxiliary 2 status event",
    31: "Auxiliary 1 status event",
}


def decode_rxstatus(hex_str: str) -> dict:
    try:
        val = int(hex_str.strip(), 16)
    except (ValueError, AttributeError):
        return {"raw_hex": hex_str, "set_bits": [], "decode_error": True}

    set_bits = [{"bit": bit, "name": name} for bit, name in _RXSTATUS_BITS.items() if val & (1 << bit)]
    return {
        "raw_hex":           hex_str.strip(),
        "set_bits":          set_bits,
        "error_flag":        bool(val & (1 << 0)),
        "spoofing_detected": bool(val & (1 << 9)),
        "jamming_detected":  bool(val & (1 << 15)),
        "antenna_open":      bool(val & (1 << 5)),
        "antenna_shorted":   bool(val & (1 << 6)),
        "position_invalid":  bool(val & (1 << 19)),
    }


def decode_aux4_tracking(hex_str: str) -> dict:
    try:
        val = int(hex_str.strip(), 16)
    except (ValueError, AttributeError):
        return {"tracking_degraded": False, "tracking_critical": False, "decode_error": True}
    return {
        "tracking_degraded": bool(val & (1 << 0)),
        "tracking_critical": bool(val & (1 << 1)),
    }


# ── ITDETECTSTATUS parser ─────────────────────────────────────────────
_ITDETECT_FIELDS_PER_ENTRY = 9


def decode_itdetectstatus(payload: str) -> dict:
    parts = [p.strip() for p in payload.split(",")]
    try:
        num_entries = int(parts[0])
    except (ValueError, IndexError):
        return {"payload": payload, "decode_error": True}

    entries = []
    for i in range(num_entries):
        base = 1 + i * _ITDETECT_FIELDS_PER_ENTRY
        if base + _ITDETECT_FIELDS_PER_ENTRY - 1 >= len(parts):
            break
        rf_path     = parts[base]
        detect_type = parts[base + 1]
        entry = {"rf_path": rf_path, "detect_type": detect_type}
        if detect_type == "SPECTRUMANALYSIS":
            try:
                entry["center_freq_mhz"] = float(parts[base + 2])
                entry["bandwidth_mhz"]   = float(parts[base + 3])
                entry["power_dbm"]       = float(parts[base + 4])
                entry["peak_psd_dbm_hz"] = float(parts[base + 5])
            except ValueError:
                entry["param_parse_error"] = True
        entries.append(entry)

    return {
        "num_entries": num_entries,
        "entries":     entries,
        "has_spectrum_interference":    any(e["detect_type"] == "SPECTRUMANALYSIS"    for e in entries),
        "has_statistical_interference": any(e["detect_type"] == "STATISTICALANALYSIS" for e in entries),
    }



def decode_bestpos_fields(fields_raw: str) -> dict:
    parts = [p.strip() for p in fields_raw.split(",")]
    return {
        "sol_status": parts[0] if len(parts) > 0 else "",
        "pos_type":   parts[1] if len(parts) > 1 else "",
        "num_svs":    int(parts[11]) if len(parts) > 11 else None,
    }


def _summarize_log(df: pd.DataFrame, filename: str) -> str:
    if df.empty:
        return f"Uploaded file '{filename}' had no parseable NovAtel ASCII log lines."

    log_counts = Counter(df["log_name_raw"])
    top_logs   = ", ".join(f"{n}({c})" for n, c in log_counts.most_common(10))

    VALID_TIME = {
        "FINESTEERING", "FINE", "FINEBACKUPSTEERING",
        "FINEADJUSTING", "COARSE", "COARSESTEERING",
        "COARSEADJUSTING", "FREEWHEELING",
    }
    valid = df[df["time_status"].isin(VALID_TIME) & (df["week"] > 0)]
    parts = [
        f"Log '{filename}': {len(df)} records, {len(log_counts)} distinct log types.",
        f"Top log types: {top_logs}.",
    ]
    if not valid.empty:
        weeks   = sorted(valid["week"].unique().tolist())
        t_start = valid["seconds"].min()
        t_end   = valid["seconds"].max()
        w_start = int(valid.loc[valid["seconds"].idxmin(), "week"])
        w_end   = int(valid.loc[valid["seconds"].idxmax(), "week"])
        duration = (weeks[-1] - weeks[0]) * 604800 + (t_end - t_start) if len(weeks) > 1 else t_end - t_start
        parts.append(
            f"File time range: {gps_to_utc_str(w_start, t_start)} to "
            f"{gps_to_utc_str(w_end, t_end)} (duration {duration:.1f}s = {duration/60:.2f} min)."
        )
    return " ".join(parts)


# ── Vectorized event index builder ────────────────────────────────────
def _build_event_index(df: pd.DataFrame) -> dict:
    """
    Pre-decode RXSTATUS bits and ITDETECTSTATUS entries at ingest time.
    Uses vectorized pandas instead of iterrows() for speed.
    """
    events: dict[str, list] = {
        "spoofing":              [],
        "jamming":               [],
        "antenna_open":          [],
        "antenna_shorted":       [],
        "position_invalid":      [],
        "tracking_degraded":     [],
        "tracking_critical":     [],
        "itdetect_interference": [],
    }

    # ── RXSTATUS — vectorized ─────────────────────────────────────────
    rxs = df[df["log_name"] == "RXSTATUS"].copy()
    if not rxs.empty:
        # Decode the status hex for every row at once
        decoded_series = rxs["rx_status"].apply(decode_rxstatus)

        for idx, (_, row) in enumerate(rxs.iterrows()):
            decoded = decoded_series.iloc[idx]
            if decoded.get("decode_error"):
                continue
            ts   = row.get("utc_time", "") or f"GPS {row['week']}w {row['seconds']:.3f}s"
            base = {
                "utc_time": ts,
                "week":     int(row["week"]),
                "seconds":  row["seconds"],
                "raw_hex":  decoded.get("raw_hex", ""),
                "set_bits": decoded.get("set_bits", []),
            }
            if decoded.get("spoofing_detected"):  events["spoofing"].append(base)
            if decoded.get("jamming_detected"):   events["jamming"].append(base)
            if decoded.get("antenna_open"):       events["antenna_open"].append(base)
            if decoded.get("antenna_shorted"):    events["antenna_shorted"].append(base)
            if decoded.get("position_invalid"):   events["position_invalid"].append(base)

            # AUX4 is at index 16 in fields_raw (0-based)
            fields = [f.strip() for f in row.get("fields_raw", "").split(",")]
            if len(fields) > 16:
                aux4 = decode_aux4_tracking(fields[16])
                if aux4.get("tracking_degraded"): events["tracking_degraded"].append(base)
                if aux4.get("tracking_critical"): events["tracking_critical"].append(base)

    # ── ITDETECTSTATUS — vectorized ───────────────────────────────────
    itd = df[df["log_name"].isin(["ITDETECTSTATUS", "ITDETECTSTAT"])].copy()
    if not itd.empty:
        decoded_series = itd["fields_raw"].apply(decode_itdetectstatus)
        for idx, (_, row) in enumerate(itd.iterrows()):
            decoded = decoded_series.iloc[idx]
            if decoded.get("decode_error"):
                continue
            ts   = row.get("utc_time", "") or f"GPS {row['week']}w {row['seconds']:.3f}s"
            week = int(row["week"])
            sow  = row["seconds"]
            for entry in decoded.get("entries", []):
                ev = {
                    "utc_time":    ts,
                    "week":        week,
                    "seconds":     sow,
                    "rf_path":     entry.get("rf_path", ""),
                    "detect_type": entry.get("detect_type", ""),
                }
                if entry.get("detect_type") == "SPECTRUMANALYSIS":
                    ev["center_freq_mhz"] = entry.get("center_freq_mhz")
                    ev["bandwidth_mhz"]   = entry.get("bandwidth_mhz")
                    ev["power_dbm"]       = entry.get("power_dbm")
                    ev["peak_psd_dbm_hz"] = entry.get("peak_psd_dbm_hz")
                events["itdetect_interference"].append(ev)

    return events


def ingest_log_file(file_bytes: bytes, filename: str, session_id: str) -> dict:
    t0   = time.time()
    text = file_bytes.decode("utf-8", errors="replace")
    df   = parse_novatel_ascii(text)

    if df.empty:
        lines  = [l for l in text.splitlines() if l.strip()]
        sample = "\n".join(lines[:5])
        raise ValueError(
            f"No NovAtel ASCII log lines found in '{filename}'. "
            f"Expected lines starting with '#LOGNAME,...;FIELDS*CRC'.\n"
            f"First lines of file:\n{sample}"
        )

    summary = _summarize_log(df, filename)
    events  = _build_event_index(df)
    # Clear stale cached answers whenever a new file is loaded
    _cache_clear_session(session_id)
    _log_store[session_id] = {
        "df":       df,
        "summary":  summary,
        "filename": filename,
        "events":   events,
    }
    print(f"[INGEST] {filename} parsed {len(df)} records session={session_id} took={time.time()-t0:.2f}s")
    return {
        "filename":  filename,
        "records":   len(df),
        "log_types": int(df["log_name"].nunique()) if not df.empty else 0,
        "summary":   summary,
    }


# ── Async-safe session context ────────────────────────────────────────
_current_session_var: contextvars.ContextVar[str] = contextvars.ContextVar(
    "_current_session_var", default=""
)


def _get_session_entry() -> dict | None:
    return _log_store.get(_current_session_var.get(""))


# ── Event merger ──────────────────────────────────────────────────────
def _merge_jamming_events(rxstatus_events: list, itdetect_events: list) -> list:
    merged: dict[tuple, dict] = {}

    for ev in rxstatus_events:
        key = (int(ev.get("week", 0)), float(ev.get("seconds", 0.0)))
        if key not in merged:
            merged[key] = {
                "utc_time": ev.get("utc_time", ""),
                "week": key[0], "seconds": key[1],
                "sources": [], "rxstatus_bits": [], "itdetect_entries": [],
            }
        if "rxstatus" not in merged[key]["sources"]:
            merged[key]["sources"].append("rxstatus")
        merged[key]["rxstatus_bits"].extend(ev.get("set_bits", []))

    for ev in itdetect_events:
        key = (int(ev.get("week", 0)), float(ev.get("seconds", 0.0)))
        if key not in merged:
            merged[key] = {
                "utc_time": ev.get("utc_time", ""),
                "week": key[0], "seconds": key[1],
                "sources": [], "rxstatus_bits": [], "itdetect_entries": [],
            }
        if "itdetectstatus" not in merged[key]["sources"]:
            merged[key]["sources"].append("itdetectstatus")
        entry = {"rf_path": ev.get("rf_path", ""), "detect_type": ev.get("detect_type", "")}
        if ev.get("detect_type") == "SPECTRUMANALYSIS":
            for f in ("center_freq_mhz", "bandwidth_mhz", "power_dbm", "peak_psd_dbm_hz"):
                if f in ev:
                    entry[f] = ev[f]
        merged[key]["itdetect_entries"].append(entry)

    return sorted(merged.values(), key=lambda e: (e["week"], e["seconds"]))


# ── Vectorized field stats ────────────────────────────────────────────
def _compute_field_stats(filtered: pd.DataFrame) -> dict:
    """
    Compute per-field-position min/max over ALL rows using vectorized pandas.
    Returns dict keyed by field position (str): {min, max, min_record, max_record}.
    Never trimmed by _cap_tool_response.
    """
    if filtered.empty:
        return {}

    # Split all fields_raw at once into a numeric matrix
    split = (
        filtered["fields_raw"]
        .str.split(",", expand=True)
        .apply(pd.to_numeric, errors="coerce")
    )

    stats: dict[str, dict] = {}
    # Build a lookup from integer position → original DataFrame index
    idx_array = filtered.index.to_numpy()

    for pos in split.columns:
        col = split[pos]
        valid_mask = col.notna()
        if not valid_mask.any():
            continue

        min_pos_in_split = col.idxmin()  # label in filtered.index
        max_pos_in_split = col.idxmax()

        def _make_rec(label) -> dict:
            row = filtered.loc[label]
            raw = row.get("fields_raw", "")
            return {
                "log_name":      row["log_name"],
                "utc_time":      row.get("utc_time", ""),
                "week":          int(row["week"]),
                "seconds":       float(row["seconds"]),
                "fields_raw":    raw,
                "fields_parsed": [f.strip() for f in raw.split(",")],
            }

        stats[str(pos)] = {
            "min":        float(col.min()),
            "max":        float(col.max()),
            "min_record": _make_rec(min_pos_in_split),
            "max_record": _make_rec(max_pos_in_split),
        }

    return stats


# ── Tool response size guard ──────────────────────────────────────────
_MAX_TOOL_RESPONSE_CHARS = 12000


def _cap_tool_response(response: dict) -> dict:
    serialised = json.dumps(response)
    if len(serialised) <= _MAX_TOOL_RESPONSE_CHARS:
        return response

    result = dict(response)
    records_were_trimmed = False

    for _ in range(20):
        if len(json.dumps(result)) <= _MAX_TOOL_RESPONSE_CHARS:
            break
        biggest_key  = None
        biggest_size = 0
        for k, v in result.items():
            if k == "field_stats":   # never trim — needed for aggregate answers
                continue
            if isinstance(v, (list, dict)):
                s = len(json.dumps(v))
                if s > biggest_size:
                    biggest_size = s
                    biggest_key  = k
        if biggest_key is None:
            break
        val = result[biggest_key]
        original_len = len(val) if isinstance(val, (list, dict)) else 0
        if isinstance(val, dict):
            items = sorted(val.items(), key=lambda x: (x[1] if isinstance(x[1], (int, float)) else 0), reverse=True)
            result[biggest_key] = dict(items[:max(1, len(items) // 2)])
            result["_note"] = f"{biggest_key} trimmed to {len(result[biggest_key])} of {original_len} entries"
        elif isinstance(val, list):
            result[biggest_key] = val[:max(1, len(val) // 2)]
            result["_note"] = f"{biggest_key} trimmed to {len(result[biggest_key])} of {original_len} entries"
            if biggest_key == "records":
                records_were_trimmed = True

    if records_were_trimmed:
        result["truncated"] = True
        total = result.get("total_matching", "?")
        kept  = len(result.get("records", []))
        result["warning"] = (
            f"records[] trimmed to {kept} of {total} by size cap. "
            f"Use field_stats for min/max/aggregate answers — it covers all {total} records."
        )

    final = json.dumps(result)
    print(f"[TOOL_CAP] {len(serialised)} → {len(final)} chars records_trimmed={records_were_trimmed}")
    return result


# ── Tools ─────────────────────────────────────────────────────────────
@tool
def kb_retriever(query: str, max_results: int = MAX_RESULTS) -> dict:
    """Search the NovAtel OEM7 documentation knowledge base."""
    t0 = time.time()
    try:
        response = get_kb_client().retrieve(
            knowledgeBaseId=KB_ID,
            retrievalQuery={"text": query},
            retrievalConfiguration={"vectorSearchConfiguration": {"numberOfResults": max_results}},
        )
        elements = []
        for result in response.get("retrievalResults", []):
            content  = result.get("content", {}).get("text", "")
            metadata = result.get("metadata", {})
            elements.append({
                "element_id":       metadata.get("element_id", ""),
                "element_type":     metadata.get("element_type", ""),
                "content_markdown": content,
                "page_number":      int(metadata.get("page_number", 0)),
                "score":            result.get("score", 0.0),
                "source_uri":       metadata.get("x-amz-bedrock-kb-source-uri", ""),
                "csv_source_uri":   metadata.get("csv_source_uri", ""),
            })
        payload = {"status": "success", "elements": elements, "total_found": len(elements)}
        _tool_call_log.append({"tool": "kb_retriever", "result": payload})
        print(f"[KB] query='{query}' results={len(elements)} took={time.time()-t0:.2f}s")
        return payload
    except Exception as e:
        print(f"[KB] error: {e}")
        return {"status": "error", "error": str(e), "elements": [], "total_found": 0}


@tool
def context_expander(
    source_uri: str,
    element_ids: list = None,
    page_numbers: list = None,
    expansion_pages: int = EXPANSION_PAGES,
) -> dict:
    """Expand context around specific KB elements. Use csv_source_uri from kb_retriever."""
    t0 = time.time()
    try:
        source_uri = _resolve_data_uri(source_uri)
        df = _download_and_parse(source_uri)
        target_pages: set[int] = set()
        if element_ids:
            for eid in element_ids:
                rows = df[df["element_id"] == eid]
                if not rows.empty:
                    target_pages.update(rows["page_number"].tolist())
        if page_numbers:
            target_pages.update(page_numbers)
        all_pages = {
            i for p in target_pages
            for i in range(p - expansion_pages, p + expansion_pages + 1)
            if i >= 0
        }
        filtered = df[df["page_number"].isin(all_pages)].copy()
        for col in ["page_number"]:
            if col in filtered.columns:
                filtered[col] = pd.to_numeric(filtered[col], errors="coerce").fillna(0).astype(int)
        for col in [c for c in filtered.columns if c != "page_number"]:
            filtered[col] = filtered[col].fillna("").astype(str)
        available_cols = [c for c in _LLM_COLS if c in filtered.columns]
        slim = filtered[available_cols].to_dict("records") if available_cols else []
        print(f"[EXPANDER] pages={sorted(all_pages)} elements={len(slim)} took={time.time()-t0:.2f}s")
        return {"status": "success", "elements": slim, "total_found": len(slim)}
    except Exception as e:
        print(f"[EXPANDER] error: {e}")
        return {"status": "error", "error": str(e), "elements": [], "total_found": 0}


@tool
def list_log_types() -> dict:
    """
    List all log types present in the uploaded file with record counts and time range.
    Use for: 'What logs are in this file?', 'summary', 'duration', 'start/end time'.
    """
    entry = _get_session_entry()
    if not entry:
        return {"status": "error", "error": "No log file has been uploaded in this session."}
    df = entry["df"]
    if df.empty:
        return {"status": "error", "error": "Uploaded log had no parseable records."}

    log_counts = df.groupby("log_name_raw").size().sort_values(ascending=False).to_dict()
    VALID_TIME = {
        "FINESTEERING", "FINE", "FINEBACKUPSTEERING",
        "FINEADJUSTING", "COARSE", "COARSESTEERING",
        "COARSEADJUSTING", "FREEWHEELING",
    }
    valid = df[df["time_status"].isin(VALID_TIME) & (df["week"] > 0)]
    if not valid.empty:
        w_start  = int(valid.loc[valid["seconds"].idxmin(), "week"])
        w_end    = int(valid.loc[valid["seconds"].idxmax(), "week"])
        s_start  = float(valid["seconds"].min())
        s_end    = float(valid["seconds"].max())
        weeks    = sorted(valid["week"].unique().tolist())
        duration = (weeks[-1] - weeks[0]) * 604800 + (s_end - s_start) if len(weeks) > 1 else s_end - s_start
        file_time_info = {
            "utc_start":         gps_to_utc_str(w_start, s_start),
            "utc_end":           gps_to_utc_str(w_end,   s_end),
            "gps_week":          w_start if w_start == w_end else f"{w_start}-{w_end}",
            "gps_seconds_start": round(s_start, 3),
            "gps_seconds_end":   round(s_end, 3),
            "duration_seconds":  round(duration, 3),
            "duration_minutes":  round(duration / 60, 4),
        }
    else:
        file_time_info = {"note": "No valid GPS time records in file."}

    log_counts_text = "\n".join(f"{name}: {count}" for name, count in log_counts.items())
    return {
        "status":             "success",
        "filename":           entry["filename"],
        "total_records":      len(df),
        "distinct_log_types": len(log_counts),
        "log_counts_text":    log_counts_text,
        "file_time_info":     file_time_info,
    }


@tool
def query_log(
    log_name: str = None,
    time_from: float = None,
    time_to: float = None,
    field_contains: str = None,
    freq_mhz: float = None,
    limit: int = None,
) -> dict:
    """
    Fetch records from the uploaded NovAtel ASCII log file.

    Args:
        log_name: log type (e.g. 'BESTPOS', 'TRACKSTAT'). Case-insensitive.
        time_from: GPS seconds-of-week lower bound.
        time_to:   GPS seconds-of-week upper bound.
        field_contains: substring match in the fields payload.
        freq_mhz: frequency in MHz for ITDETECTSTATUS search (±1 MHz tolerance).
        limit: max records to return. OMIT for aggregate/min/max queries.

    Returns field_stats with server-side min/max over ALL records (never trimmed).
    Use field_stats for highest/lowest/peak questions, not records[].
    """
    t0 = time.time()
    entry = _get_session_entry()
    if not entry:
        return {"status": "error", "error": "No log file has been uploaded in this session."}
    df = entry["df"]
    if df.empty:
        return {"status": "error", "error": "Uploaded log had no parseable records."}

    # ── Frequency search ──────────────────────────────────────────────
    if freq_mhz is not None:
        tolerance_mhz = 1.0
        target_log    = log_name or "ITDETECTSTATUS"

        def _freq_match_mhz(fields_raw: str) -> bool:
            for p in fields_raw.split(","):
                try:
                    if abs(float(p.strip()) - freq_mhz) <= tolerance_mhz:
                        return True
                except ValueError:
                    continue
            return False

        filtered = df[df["log_name"].str.upper() == target_log.upper()].copy()
        if time_from is not None: filtered = filtered[filtered["seconds"] >= time_from]
        if time_to   is not None: filtered = filtered[filtered["seconds"] <= time_to]
        filtered = filtered[filtered["fields_raw"].apply(_freq_match_mhz)]

        total     = len(filtered)
        truncated = limit is not None and total > limit
        trimmed   = filtered.head(limit) if limit is not None else filtered
        field_stats = _compute_field_stats(filtered)

        # Vectorized record building
        records = _build_records_list(trimmed)

        result = {
            "status":            "success",
            "freq_searched_mhz": freq_mhz,
            "tolerance_mhz":     tolerance_mhz,
            "total_matching":    total,
            "returned":          len(records),
            "truncated":         truncated,
            "field_stats":       field_stats,
            "records":           records,
        }
        if truncated:
            result["warning"] = (
                f"Results truncated to {limit} of {total}. "
                f"Use field_stats for min/max — it covers all {total} records."
            )
        print(f"[QUERY_LOG] freq_mhz={freq_mhz} total={total} returned={len(records)} took={time.time()-t0:.2f}s")
        return _cap_tool_response(result)

    # ── Standard filter ───────────────────────────────────────────────
    filtered = df
    if log_name:
        filtered = filtered[filtered["log_name"].str.upper() == log_name.upper()]
    if time_from is not None:
        filtered = filtered[filtered["seconds"] >= time_from]
    if time_to is not None:
        filtered = filtered[filtered["seconds"] <= time_to]
    if field_contains:
        filtered = filtered[filtered["fields_raw"].str.contains(field_contains, case=False, na=False)]

    total       = len(filtered)
    truncated   = limit is not None and total > limit
    trimmed     = filtered.head(limit) if limit is not None else filtered
    field_stats = _compute_field_stats(filtered)
    records     = _build_records_list(trimmed)

    result = {
        "status":         "success",
        "total_matching": total,
        "returned":       len(records),
        "truncated":      truncated,
        "field_stats":    field_stats,
        "records":        records,
    }
    if truncated:
        result["warning"] = (
            f"Results truncated to {limit} of {total}. "
            f"Use field_stats for min/max — it covers all {total} records."
        )
    print(f"[QUERY_LOG] log={log_name} total={total} returned={len(records)} took={time.time()-t0:.2f}s")
    return _cap_tool_response(result)


def _build_records_list(df_slice: pd.DataFrame) -> list[dict]:
    """Build the records list from a DataFrame slice without iterrows()."""
    if df_slice.empty:
        return []
    records = []
    for col in ["log_name", "utc_time", "seconds", "week", "time_status", "rx_status", "fields_raw"]:
        if col not in df_slice.columns:
            df_slice = df_slice.copy()
            df_slice[col] = ""
    for row in df_slice.itertuples(index=False):
        fields_raw = row.fields_raw or ""
        records.append({
            "log_name":      row.log_name,
            "utc_time":      row.utc_time,
            "seconds":       row.seconds,
            "week":          int(row.week),
            "time_status":   row.time_status,
            "rx_status":     row.rx_status,
            "fields_raw":    fields_raw,
            "fields_parsed": [f.strip() for f in fields_raw.split(",")],
        })
    return records


@tool
def analyze_events(event_type: str) -> dict:
    """
    Return pre-decoded security/quality events from the uploaded log.
    Use for spoofing, jamming, interference, antenna issues, tracking, position validity.
    Do NOT decode hex values yourself — use this tool.

    event_type options:
        'spoofing'              — RXSTATUS bit 9
        'jamming'               — RXSTATUS bit 15
        'antenna_open'          — RXSTATUS bit 5
        'antenna_shorted'       — RXSTATUS bit 6
        'position_invalid'      — RXSTATUS bit 19
        'tracking_degraded'     — AUX4 bit 0 (<60% satellites tracked well)
        'tracking_critical'     — AUX4 bit 1 (<15% satellites tracked well)
        'itdetect_interference' — all ITDETECTSTATUS interference entries
        'all'                   — summary counts of all event types
    """
    entry = _get_session_entry()
    if not entry:
        return {"status": "error", "error": "No log file has been uploaded in this session."}

    events = entry.get("events", {})

    if event_type == "all":
        return {"status": "success", "event_type": "all", "summary": {k: len(v) for k, v in events.items()}}

    if event_type in ("jamming", "spoofing"):
        merged   = _merge_jamming_events(events.get(event_type, []), events.get("itdetect_interference", []))
        both     = [e for e in merged if "rxstatus" in e["sources"] and "itdetectstatus" in e["sources"]]
        rx_only  = [e for e in merged if e["sources"] == ["rxstatus"]]
        itd_only = [e for e in merged if e["sources"] == ["itdetectstatus"]]
        MAX_EVENTS = 50
        return _cap_tool_response({
            "status":                    "success",
            "event_type":                event_type,
            "total_unique_events":       len(merged),
            "rxstatus_only_count":       len(rx_only),
            "itdetectstatus_only_count": len(itd_only),
            "both_sources_count":        len(both),
            "events":                    merged[:MAX_EVENTS],
            "truncated":                 len(merged) > MAX_EVENTS,
            "note": (
                f"{len(merged)} unique {event_type} events after merging same-timestamp entries. "
                f"{len(both)} confirmed by both sources, {len(rx_only)} RXSTATUS-only, "
                f"{len(itd_only)} ITDETECTSTATUS-only. "
                "Use total_unique_events as the authoritative count."
            ),
        })

    if event_type not in events:
        return {
            "status": "error",
            "error":  f"Unknown event_type '{event_type}'. Valid: {sorted(events.keys()) + ['all']}",
        }

    result     = events[event_type]
    MAX_EVENTS = 50
    return _cap_tool_response({
        "status":       "success",
        "event_type":   event_type,
        "total_events": len(result),
        "events":       result[:MAX_EVENTS],
        "truncated":    len(result) > MAX_EVENTS,
        "note": (
            f"Total occurrences: {len(result)}. utc_time is pre-computed — report directly."
            + (f" Showing first {MAX_EVENTS}." if len(result) > MAX_EVENTS else "")
        ),
    })


# ── Agent system prompt ───────────────────────────────────────────────
_AGENT_SYSTEM_PROMPT = """You are a NovAtel OEM7 assistant. Answer questions about NovAtel documentation OR an uploaded ASCII log file.

TOOLS:
- list_log_types(): all log types + counts + file UTC/GPS start/end/duration.
- query_log(log_name, time_from, time_to, field_contains, freq_mhz, limit=None): fetch records + field_stats.
  FIELD_STATS — use for ALL aggregate questions (highest/lowest/peak/min/max):
    Keyed by field position (string). Each: {min, max, min_record, max_record}.
    ALWAYS use field_stats["N"]["max"/"min"] for peak/lowest. NEVER scan records[].
  LIMIT: OMIT for aggregate queries. Only pass integer for preview/sample requests.
- analyze_events(event_type): pre-decoded RXSTATUS/ITDETECTSTATUS events.
  Valid: spoofing, jamming, antenna_open, antenna_shorted, position_invalid,
         tracking_degraded, tracking_critical, itdetect_interference, all.
  For jamming/spoofing: use total_unique_events as the count (events are merged by timestamp).
- kb_retriever(query): search NovAtel OEM7 documentation.
- context_expander(csv_source_uri, element_ids): expand KB chunks.

ROUTING:
- "what logs are in this file" / "list logs" / "summary" / "duration" → list_log_types()
- "show me X logs" / "position logs" / "velocity logs" → query_log(log_name=...)
- Spoofing / jamming / interference / antenna / tracking → analyze_events()
- Doc question → kb_retriever()
- Unknown which log → list_log_types() then query_log()

ANSWERING:
- Always report utc_time directly — never recalculate from GPS seconds.
- Use field_stats for any min/max/peak/aggregate answer.
- total_matching from query_log = exact count. Never count records[] yourself.
- Max 4 tool calls per question.
- Answer only from tool results, not from training knowledge about field values.
"""


# ── Agent factory ─────────────────────────────────────────────────────
_agent = None


def get_agent():
    global _agent
    if _agent is None:
        _agent = create_react_agent(
            model=get_llm(),
            tools=[list_log_types, query_log, analyze_events, kb_retriever, context_expander],
        )
    return _agent


def run_agent(prompt: str, history: list, session_id: str = "") -> str:
    """
    Run the ReAct agent with streaming so Streamlit gets live status updates.
    """
    t0 = time.time()
    _tool_call_log.clear()
    messages = [SystemMessage(content=_AGENT_SYSTEM_PROMPT)] + history + [HumanMessage(content=prompt)]

    if session_id:
        set_status(session_id, "Searching knowledge base...")

    try:
        final_answer = ""
        agent = get_agent()

        for event in agent.stream(
            {"messages": messages},
            config={"recursion_limit": 12},
            stream_mode="values",
        ):
            if "messages" not in event:
                continue
            last_msg = event["messages"][-1]
            msg_type = last_msg.__class__.__name__

            if msg_type == "AIMessage":
                tool_calls = getattr(last_msg, "tool_calls", None) or []
                if tool_calls:
                    tool_name = (
                        tool_calls[0].get("name", "")
                        if isinstance(tool_calls[0], dict)
                        else getattr(tool_calls[0], "name", "")
                    )
                    status_map = {
                        "list_log_types":  "Listing log types in file...",
                        "query_log":       "Querying log records...",
                        "analyze_events":  "Analyzing security events...",
                        "kb_retriever":    "Searching documentation...",
                        "context_expander":"Expanding documentation context...",
                    }
                    if session_id:
                        set_status(session_id, status_map.get(tool_name, "Processing..."))
                elif last_msg.content:
                    if session_id:
                        set_status(session_id, "Formulating response...")
                    final_answer = last_msg.content

            elif msg_type == "ToolMessage":
                if session_id:
                    set_status(session_id, "Processing results...")

        if not final_answer:
            # Fallback: non-streaming invoke
            result = get_agent().invoke(
                {"messages": messages},
                config={"recursion_limit": 12},
            )
            final_answer = result["messages"][-1].content

        print(f"[AGENT] took={time.time()-t0:.2f}s")
        if session_id:
            clear_status(session_id)
        return final_answer

    except Exception as e:
        err = str(e)
        if "Input is too long" in err or "ValidationException" in err:
            print("[AGENT] token overflow, retrying without history")
            messages_slim = [SystemMessage(content=_AGENT_SYSTEM_PROMPT), HumanMessage(content=prompt)]
            try:
                result = get_agent().invoke(
                    {"messages": messages_slim},
                    config={"recursion_limit": 12},
                )
                answer = result["messages"][-1].content
                if session_id:
                    clear_status(session_id)
                return answer
            except Exception as e2:
                if session_id:
                    clear_status(session_id)
                raise e2
        if session_id:
            clear_status(session_id)
        raise


# ── Direct handlers (zero LLM calls) ─────────────────────────────────
_VALID_TIME_STATUSES = {
    "FINESTEERING", "FINE", "FINEBACKUPSTEERING", "FINEADJUSTING",
    "COARSE", "COARSESTEERING", "COARSEADJUSTING", "FREEWHEELING",
}

_LIST_KEYWORDS = (
    "list", "what log", "all log", "log type", "instance", "how many log",
    "available log", "logs in", "logs are", "logs present", "logs there",
)
_TIME_KEYWORDS = (
    "start time", "end time", "duration", "time range", "start and end",
    "when does", "file time", "gps time", "utc time", "how long", "begin", "finish",
)
_EVENT_KEYWORDS = (
    "spoofing", "jamming", "interference", "antenna", "tracking", "position invalid",
    "scintillation", "jammer", "spoof",
)


def _direct_list_logs(log_entry: dict) -> dict:
    df         = log_entry["df"]
    log_counts = df.groupby("log_name_raw").size().sort_values(ascending=False)
    lines      = [f"| {n} | {c} |" for n, c in log_counts.items()]
    table      = "| Log Type | Count |\n|---|---|\n" + "\n".join(lines)
    return {"result": (
        f"**{len(log_counts)} log types** in `{log_entry['filename']}` "
        f"({len(df)} total records):\n\n{table}"
    )}


def _direct_time_range(log_entry: dict) -> dict:
    df    = log_entry["df"]
    valid = df[df["time_status"].isin(_VALID_TIME_STATUSES) & (df["week"] > 0)]
    if valid.empty:
        return {"result": "No records with valid GPS time found in this file."}
    w_s   = int(valid.loc[valid["seconds"].idxmin(), "week"])
    w_e   = int(valid.loc[valid["seconds"].idxmax(), "week"])
    s_s   = float(valid["seconds"].min())
    s_e   = float(valid["seconds"].max())
    weeks = sorted(valid["week"].unique().tolist())
    dur   = (weeks[-1] - weeks[0]) * 604800 + (s_e - s_s) if len(weeks) > 1 else s_e - s_s
    return {"result": (
        f"**File time range for `{log_entry['filename']}`:**\n\n"
        f"| | GPS | UTC |\n|---|---|---|\n"
        f"| Start | Week {w_s}, {s_s:.3f}s | {gps_to_utc_str(w_s, s_s)} |\n"
        f"| End   | Week {w_e}, {s_e:.3f}s | {gps_to_utc_str(w_e, s_e)} |\n\n"
        f"**Duration:** {dur:.3f}s ({dur/60:.2f} min)"
    )}


def _direct_analyze_events(log_entry: dict, event_type: str) -> dict | None:
    """
    Return a pre-formatted answer for security event questions — zero LLM calls.
    Returns None if the event_type is not recognized (falls through to agent).
    """
    events = log_entry.get("events", {})
    valid_types = {
        "spoofing", "jamming", "antenna_open", "antenna_shorted",
        "position_invalid", "tracking_degraded", "tracking_critical",
        "itdetect_interference",
    }
    if event_type not in valid_types and event_type != "all":
        return None

    if event_type == "all":
        summary = {k: len(v) for k, v in events.items()}
        lines   = [f"| {k.replace('_', ' ').title()} | {v} |" for k, v in summary.items()]
        table   = "| Event Type | Count |\n|---|---|\n" + "\n".join(lines)
        total   = sum(summary.values())
        return {"result": f"**Event summary for `{log_entry['filename']}`:**\n\n{table}\n\nTotal: {total} events across all categories."}

    if event_type in ("jamming", "spoofing"):
        merged   = _merge_jamming_events(events.get(event_type, []), events.get("itdetect_interference", []))
        total    = len(merged)
        both     = sum(1 for e in merged if "rxstatus" in e["sources"] and "itdetectstatus" in e["sources"])
        rx_only  = sum(1 for e in merged if e["sources"] == ["rxstatus"])
        itd_only = sum(1 for e in merged if e["sources"] == ["itdetectstatus"])

        label = "Jamming" if event_type == "jamming" else "Spoofing"
        if total == 0:
            return {"result": f"**No {label.lower()} detected** in `{log_entry['filename']}`."}

        ts_list = "\n".join(f"- {e['utc_time']}" for e in merged[:50])
        suffix  = f"\n\n*... and {total - 50} more events.*" if total > 50 else ""
        return {"result": (
            f"**{total} {label} event(s) detected** in `{log_entry['filename']}`.\n\n"
            f"Sources: {both} confirmed by both RXSTATUS+ITDETECTSTATUS, "
            f"{rx_only} RXSTATUS-only, {itd_only} ITDETECTSTATUS-only.\n\n"
            f"**Event timestamps (UTC):**\n{ts_list}{suffix}"
        )}

    # Generic event types
    result = events.get(event_type, [])
    total  = len(result)
    label  = event_type.replace("_", " ").title()
    if total == 0:
        return {"result": f"**No {label} events detected** in `{log_entry['filename']}`."}

    ts_list = "\n".join(f"- {e['utc_time']}" for e in result[:50])
    suffix  = f"\n\n*... and {total - 50} more events.*" if total > 50 else ""
    return {"result": (
        f"**{total} {label} event(s)** in `{log_entry['filename']}`.\n\n"
        f"**Timestamps (UTC):**\n{ts_list}{suffix}"
    )}


def _detect_event_type(prompt_lower: str) -> str | None:
    """Map question text to an analyze_events event_type, or None."""
    if any(w in prompt_lower for w in ("spoof",)):
        return "spoofing"
    if any(w in prompt_lower for w in ("jam", "jammer")):
        return "jamming"
    if "antenna" in prompt_lower and "open" in prompt_lower:
        return "antenna_open"
    if "antenna" in prompt_lower and ("short" in prompt_lower or "circuit" in prompt_lower):
        return "antenna_shorted"
    if "position invalid" in prompt_lower or "position solution" in prompt_lower:
        return "position_invalid"
    if "tracking" in prompt_lower and ("critical" in prompt_lower or "15%" in prompt_lower):
        return "tracking_critical"
    if "tracking" in prompt_lower and ("degrad" in prompt_lower or "60%" in prompt_lower):
        return "tracking_degraded"
    if "interference" in prompt_lower or "itdetect" in prompt_lower:
        return "itdetect_interference"
    if any(w in prompt_lower for w in ("event", "all event", "summarize", "summary")):
        return "all"
    return None


# ── S3 helper ─────────────────────────────────────────────────────────
def upload_to_s3(content: bytes, filename: str) -> str:
    key = f"logs/{filename}"
    get_s3_client().put_object(Bucket=S3_BUCKET, Key=key, Body=content)
    return key


# ── Main entrypoint ───────────────────────────────────────────────────
@app.entrypoint
async def invoke(payload):
    if isinstance(payload, dict):
        prompt     = payload.get("prompt", "")
        file_b64   = payload.get("file", None)
        s3_key_in  = payload.get("s3_key", None)
        filename   = payload.get("filename", "log.txt")
        session_id = payload.get("session_id", "default-session")
    else:
        prompt = str(payload); file_b64 = s3_key_in = None
        filename = "log.txt"; session_id = "default-session"

    # ── File ingest ───────────────────────────────────────────────────
    if file_b64:
        try:
            set_status(session_id, "Parsing log file...")
            file_bytes = base64.b64decode(file_b64)
            if S3_BUCKET and len(file_bytes) > SIZE_THRESHOLD:
                set_status(session_id, "Uploading to cloud storage...")
                upload_to_s3(file_bytes, filename)
            set_status(session_id, "Building event index...")
            info = ingest_log_file(file_bytes, filename, session_id)
            clear_status(session_id)
            return {
                "result": (
                    f"Parsed '{info['filename']}': {info['records']} records across "
                    f"{info['log_types']} log types. Ask me anything — "
                    "e.g. 'was there jamming?', 'show BESTPOS records', 'what's the time range?'."
                ),
                "summary": info["summary"],
            }
        except Exception as e:
            clear_status(session_id)
            return {"result": f"Error parsing log file: {e}"}

    elif s3_key_in:
        try:
            set_status(session_id, "Loading file from cloud storage...")
            obj  = get_s3_client().get_object(Bucket=S3_BUCKET, Key=s3_key_in)
            set_status(session_id, "Parsing log file...")
            info = ingest_log_file(obj["Body"].read(), filename, session_id)
            clear_status(session_id)
            return {
                "result": (
                    f"Parsed '{info['filename']}': {info['records']} records across "
                    f"{info['log_types']} log types. Ask me anything about this log."
                ),
                "summary": info["summary"],
            }
        except Exception as e:
            clear_status(session_id)
            return {"result": f"Error reading from S3: {e}"}

    # ── Q&A path ──────────────────────────────────────────────────────
    print(f"[QA] prompt={prompt!r} session_id={session_id!r}")
    try:
        apply_guardrail(prompt, source="INPUT")
    except ValueError as e:
        return {"result": str(e)}

    # ── Cache hit: return instantly without touching the agent ────────
    cached = _cache_get(session_id, prompt)
    if cached:
        print(f"[CACHE] hit for session={session_id} prompt='{prompt[:60]}'")
        return {"result": cached}

    _current_session_var.set(session_id)
    _tool_call_log.clear()

    # Load memory history
    history = []
    if MEMORY_ID:
        try:
            mem_events = get_memory_client().list_events(
                memory_id=MEMORY_ID, actor_id=ACTOR_ID,
                session_id=session_id, max_results=10,
            )
            for event in mem_events:
                for item in event.get("payload", []):
                    conv = item.get("conversational", {})
                    role = conv.get("role", "")
                    text = conv.get("content", {}).get("text", "")
                    if role == "USER":
                        history.append(HumanMessage(content=text))
                    elif role == "ASSISTANT":
                        history.append(AIMessage(content=text))
        except Exception as e:
            print(f"Memory retrieve error: {e}")

    # Trim history
    history = history[-6:]
    history = [
        msg.__class__(content=msg.content[:800] + "…[truncated]")
        if isinstance(msg.content, str) and len(msg.content) > 800 else msg
        for msg in history
    ]

    log_entry = _log_store.get(session_id)
    p = prompt.lower()

    # ── Direct handler: list logs ─────────────────────────────────────
    if log_entry and any(kw in p for kw in _LIST_KEYWORDS):
        # Don't shortcut if user is asking for actual log records (e.g. "show me position logs")
        asking_for_records = any(w in p for w in ("show", "give", "display", "fetch", "get"))
        if not asking_for_records:
            print("[DIRECT] → list logs")
            set_status(session_id, "Listing log types...")
            result = _direct_list_logs(log_entry)
            clear_status(session_id)
            return result

    # ── Direct handler: time range ────────────────────────────────────
    if log_entry and any(kw in p for kw in _TIME_KEYWORDS):
        print("[DIRECT] → time range")
        set_status(session_id, "Computing file time range...")
        result = _direct_time_range(log_entry)
        clear_status(session_id)
        return result

    # ── Direct handler: security events (zero LLM) ───────────────────
    if log_entry and any(kw in p for kw in _EVENT_KEYWORDS):
        event_type = _detect_event_type(p)
        if event_type:
            print(f"[DIRECT] → analyze_events({event_type})")
            set_status(session_id, f"Analyzing {event_type.replace('_', ' ')} events...")
            result = _direct_analyze_events(log_entry, event_type)
            clear_status(session_id)
            if result:
                output = result["result"]
                # Save to memory
                if MEMORY_ID:
                    try:
                        get_memory_client().create_event(
                            memory_id=MEMORY_ID, actor_id=ACTOR_ID, session_id=session_id,
                            messages=[(prompt, "USER"), (output, "ASSISTANT")],
                        )
                    except Exception as e:
                        print(f"Memory save error: {e}")
                return {"result": output}

    # ── Agent path ────────────────────────────────────────────────────
    if log_entry:
        prompt_for_agent = (
            f"[File loaded: '{log_entry['filename']}'. "
            f"Use list_log_types(), query_log(), or analyze_events() to answer.]\n\n"
            f"{prompt}"
        )
        set_status(session_id, "Analyzing log data...")
    else:
        prompt_for_agent = prompt
        set_status(session_id, "Searching documentation...")

    try:
        output = run_agent(prompt_for_agent, history, session_id)
    except GraphRecursionError:
        clear_status(session_id)
        return {"result": "Hit the tool-call budget before finding a confident answer. Try rephrasing."}
    except Exception as e:
        clear_status(session_id)
        return {"result": f"Agent error: {e}"}

    try:
        apply_guardrail(output, source="OUTPUT")
    except ValueError as e:
        clear_status(session_id)
        return {"result": str(e)}

    if MEMORY_ID:
        try:
            get_memory_client().create_event(
                memory_id=MEMORY_ID, actor_id=ACTOR_ID, session_id=session_id,
                messages=[(prompt, "USER"), (output, "ASSISTANT")],
            )
        except Exception as e:
            print(f"Memory save error: {e}")

    return {"result": output}


if __name__ == "__main__":
    app.run()